# Card files are auto-formatted by card-to-archive.yml after merge.
# Excluding them here prevents CI from failing on fork PRs (where the
# prettier action can't write back to the contributor's branch).
cards/*.html

# Husky git hooks (no file extension — Prettier can't infer a parser)
.husky/

# Archive data files
archive/cards/*.json
archive/archiveFilesTotal.js
