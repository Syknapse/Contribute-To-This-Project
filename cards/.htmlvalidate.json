{
  "extends": ["html-validate:recommended"],
  "rules": {
    "doctype-html": "off",
    "no-trailing-whitespace": "off",
    "void-style": ["error", { "style": "omit" }],
    "attr-quotes": ["error", { "style": "double", "unquoted": false }],
    "require-closing-tags": "error",
    "no-duplicate-id": "error",
    "no-inline-style": "off"
  }
}
